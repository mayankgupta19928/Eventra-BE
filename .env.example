# --- Run app on your machine (Postgres via docker compose or local install) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=eventra
DB_PASSWORD=eventra
DB_NAME=eventra

PORT=9001
JWT_SECRET=replace-with-a-long-random-secret-for-production-min-32-chars
TYPEORM_LOGGING=false

# CORS (optional): comma-separated origins, e.g. http://localhost:3000
# CORS_ORIGINS=http://localhost:3000

# --- When the API runs inside Docker Compose ---
# Do not set DB_HOST=localhost there. Compose sets DB_HOST=postgres for the `api` service
# (the hostname is the Postgres *service name*, on the same Docker network).
